/* AI虚拟形象聊天系统 - 高级企业商用渐变配色样式表 */

/* CSS自定义属性 - 高级企业级渐变配色 */
:root {
  /* 主要颜色 - 深蓝到紫色渐变 */
  --primary-color: #2563eb;
  --primary-hover-color: #1d4ed8;
  --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --primary-gradient-hover: linear-gradient(135deg, #5a6fd8 0%, #6a4190 100%);
  
  /* 次要颜色 - 金色到橙色渐变 */
  --secondary-color: #64748b;
  --secondary-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  
  /* 强调色 - 蓝绿渐变 */
  --accent-gradient: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  
  /* 成功/警告/危险色 */
  --success-color: #10b981;
  --success-gradient: linear-gradient(135deg, #0ba360 0%, #3cba92 100%);
  --warning-color: #f59e0b;
  --warning-gradient: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
  --danger-color: #ef4444;
  --danger-gradient: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
  --info-color: #3b82f6;
  --info-gradient: linear-gradient(135deg, #30cfd0 0%, #330867 100%);
  
  /* 中性色 */
  --white: #ffffff;
  --gray-50: #f9fafb;
  --gray-100: #f3f4f6;
  --gray-200: #e5e7eb;
  --gray-300: #d1d5db;
  --gray-400: #9ca3af;
  --gray-500: #6b7280;
  --gray-600: #4b5563;
  --gray-700: #374151;
  --gray-800: #1f2937;
  --gray-900: #111827;
  --black: #000000;
  
  /* 背景色 - 使用渐变 */
  --bg-primary: var(--white);
  --bg-secondary: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  --bg-tertiary: linear-gradient(135deg, #e0eafc 0%, #cfdef3 100%);
  --bg-header: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --bg-card: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.9) 100%);
  
  /* 文字颜色 */
  --text-primary: var(--gray-900);
  --text-secondary: var(--gray-600);
  --text-tertiary: var(--gray-500);
  --text-inverse: var(--white);
  
  /* 边框 */
  --border-color: var(--gray-200);
  --border-radius-sm: 0.25rem;
  --border-radius-md: 0.375rem;
  --border-radius-lg: 0.5rem;
  --border-radius-xl: 0.75rem;
  
  /* 阴影 */
  --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  
  /* 间距 */
  --spacing-1: 0.25rem;
  --spacing-2: 0.5rem;
  --spacing-3: 0.75rem;
  --spacing-4: 1rem;
  --spacing-5: 1.25rem;
  --spacing-6: 1.5rem;
  --spacing-8: 2rem;
  --spacing-10: 2.5rem;
  --spacing-12: 3rem;
  
  /* 字体 */
  --font-family-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans', sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji';
  --font-size-xs: 0.75rem;
  --font-size-sm: 0.875rem;
  --font-size-base: 1rem;
  --font-size-lg: 1.125rem;
  --font-size-xl: 1.25rem;
  --font-size-2xl: 1.5rem;
  --font-size-3xl: 1.875rem;
  --font-size-4xl: 2.25rem;
  
  /* 其他 */
  --transition-base: all 0.2s ease-in-out;
  --transition-fast: all 0.1s ease-in-out;
  --z-index-dropdown: 1000;
  --z-index-sticky: 1020;
  --z-index-fixed: 1030;
  --z-index-modal-backdrop: 1040;
  --z-index-modal: 1050;
  --z-index-popover: 1060;
  --z-index-tooltip: 1070;
}

/* 基础样式重置 */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: var(--font-family-sans);
  background: var(--bg-secondary);
  color: var(--text-primary);
  height: 100vh;
  overflow: hidden;
}

/* 应用容器 */
.app-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-secondary);
  overflow: hidden;
}

/* 头部样式 */
.header {
  background: var(--bg-header);
  color: var(--text-inverse);
  box-shadow: var(--shadow-lg);
  z-index: var(--z-index-sticky);
  flex-shrink: 0;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-4) var(--spacing-6);
  max-width: 100%;
}

.logo {
  display: flex;
  align-items: center;
  gap: var(--spacing-3);
}

.logo-icon {
  font-size: var(--font-size-2xl);
}

.logo-text h1 {
  font-size: var(--font-size-xl);
  font-weight: 700;
  margin-bottom: var(--spacing-1);
}

.logo-text .subtitle {
  font-size: var(--font-size-xs);
  opacity: 0.9;
}

.header-controls {
  display: flex;
  align-items: center;
  gap: var(--spacing-2);
}

.status-indicator {
  display: flex;
  align-items: center;
  gap: var(--spacing-1);
  margin-right: var(--spacing-3);
  font-size: var(--font-size-sm);
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #ff4d4d;
}

.status-dot.connected {
  background: #4dff88;
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: var(--spacing-2);
  padding: var(--spacing-2) var(--spacing-4);
  border: none;
  border-radius: var(--border-radius-md);
  font-size: var(--font-size-sm);
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition-base);
  text-decoration: none;
  background: rgba(255, 255, 255, 0.15);
  color: var(--text-inverse);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.btn:hover {
  background: rgba(255, 255, 255, 0.25);
  transform: translateY(-1px);
}

.btn-ghost {
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.btn-ghost:hover {
  background: rgba(255, 255, 255, 0.1);
}

.btn-primary {
  background: var(--primary-gradient);
  color: var(--text-inverse);
  border: none;
  font-weight: 700;
  box-shadow: var(--shadow-md);
}

.btn-primary:hover {
  background: var(--primary-gradient-hover);
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

.btn-large {
  padding: var(--spacing-4) var(--spacing-6);
  font-size: var(--font-size-base);
}

.btn-small {
  padding: var(--spacing-1) var(--spacing-3);
  font-size: var(--font-size-sm);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.15);
  color: var(--text-inverse);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.btn-secondary:hover {
  background: rgba(255, 255, 255, 0.25);
}

/* 主要内容区域 */
.main-content {
  flex: 1;
  overflow: hidden;
  padding: var(--spacing-4);
  display: flex;
  flex-direction: column;
}

.chat-layout {
  display: flex;
  height: 100%;
  gap: var(--spacing-4);
  flex: 1;
  min-height: 0; /* 允许flex容器收缩 */
}

/* 数字人区域 */
.avatar-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: var(--bg-card);
  backdrop-filter: blur(20px);
  border-radius: var(--border-radius-xl);
  box-shadow: var(--shadow-lg);
  border: 1px solid rgba(255, 255, 255, 0.2);
  overflow: hidden;
  min-width: 0;
}

.avatar-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
}

.avatar-header {
  padding: var(--spacing-4);
  border-bottom: 1px solid var(--border-color);
  flex-shrink: 0;
}

.avatar-header h3 {
  margin: 0;
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.avatar-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: var(--spacing-2);
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.avatar-display-container {
  flex: 1;
  position: relative;
  min-height: 0; /* 允许flex容器收缩 */
  background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-2);
}

.avatar-video-wrapper {
  width: 100%;
  height: 100%;
  max-width: 100%;
  max-height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  aspect-ratio: 16 / 9;
  min-height: 0;
  overflow: hidden;
  border-radius: var(--border-radius-lg);
  background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
}

.avatar-video-wrapper img {
  width: 100%;
  height: 100%;
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  display: block;
  border-radius: var(--border-radius-lg);
}

.avatar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-2);
  color: var(--text-tertiary);
}

.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid var(--border-color);
  border-top: 3px solid var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.avatar-controls {
  padding: var(--spacing-4);
  border-top: 1px solid var(--border-color);
  flex-shrink: 0;
}

.avatar-control-buttons {
  display: flex;
  gap: var(--spacing-2);
  margin-top: var(--spacing-3);
  justify-content: center;
}

.avatar-control-buttons .btn {
  flex: 1;
  min-width: auto;
  padding: var(--spacing-2) var(--spacing-3);
  font-size: var(--font-size-sm);
}

.avatar-control-buttons .btn i {
  margin-right: var(--spacing-1);
}

.local-video-wrapper {
  position: absolute;
  top: var(--spacing-4);
  right: var(--spacing-4);
  width: 120px;
  height: 90px;
  background-color: var(--bg-primary);
  border: 1px solid var(--border-color);
  border-radius: var(--border-radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.local-video-wrapper video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.video-label {
  position: absolute;
  bottom: var(--spacing-1);
  left: var(--spacing-1);
  right: var(--spacing-1);
  background-color: rgba(0, 0, 0, 0.7);
  color: var(--text-inverse);
  font-size: var(--font-size-xs);
  text-align: center;
  padding: 1px;
  border-radius: var(--border-radius-sm);
}

.media-controls {
  padding: var(--spacing-4);
  background-color: var(--bg-tertiary);
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow-sm);
  flex-shrink: 0;
}

.control-group {
  display: flex;
  justify-content: center;
  gap: var(--spacing-4);
}

.control-btn {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  border: none;
  background: var(--bg-primary);
  color: var(--text-primary);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-lg);
  transition: var(--transition-base);
  border: 1px solid var(--border-color);
  box-shadow: var(--shadow-sm);
}

.control-btn:hover {
  background: var(--bg-secondary);
  color: var(--text-primary);
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.control-btn.active {
  background: var(--primary-gradient);
  color: var(--text-inverse);
  border-color: transparent;
}

/* 聊天区域 */
.chat-section {
  flex: 0 0 35%;
  display: flex;
  flex-direction: column;
  background: var(--bg-card);
  backdrop-filter: blur(20px);
  border-radius: var(--border-radius-xl);
  box-shadow: var(--shadow-lg);
  border: 1px solid rgba(255, 255, 255, 0.2);
  overflow: hidden;
  max-width: 500px;
  min-width: 0;
}

.chat-header {
  padding: var(--spacing-4);
  border-bottom: 1px solid var(--border-color);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.chat-title h3 {
  color: var(--text-primary);
  font-size: var(--font-size-lg);
  font-weight: 600;
  margin: 0;
}

.chat-title .chat-subtitle {
  color: var(--text-secondary);
  font-size: var(--font-size-sm);
  margin-top: var(--spacing-1);
}

.chat-actions {
  display: flex;
  gap: var(--spacing-2);
}

.chat-messages {
  flex: 1;
  padding: var(--spacing-4);
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-3);
  min-height: 0;
}

.message {
  max-width: 80%;
  padding: var(--spacing-3);
  border-radius: var(--border-radius-lg);
  animation: slideIn 0.3s ease-out;
}

.message.user {
  align-self: flex-end;
  background: var(--primary-gradient);
  color: var(--text-inverse);
  border-bottom-right-radius: var(--border-radius-sm);
}

.message.ai {
  align-self: flex-start;
  background: var(--bg-primary);
  color: var(--text-primary);
  border: 1px solid var(--border-color);
  border-bottom-left-radius: var(--border-radius-sm);
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-2);
  font-size: var(--font-size-sm);
  opacity: 0.8;
}

.message-content {
  line-height: 1.5;
}

.welcome-message {
  background: var(--bg-primary);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-6);
  text-align: center;
  margin: auto;
  border: 1px solid var(--border-color);
  box-shadow: var(--shadow-sm);
  max-width: 400px;
}

.welcome-icon {
  font-size: var(--font-size-4xl);
  color: var(--text-tertiary);
  margin-bottom: var(--spacing-4);
}

.welcome-content h4 {
  color: var(--text-primary);
  font-size: var(--font-size-xl);
  margin-bottom: var(--spacing-3);
}

.welcome-content p {
  color: var(--text-secondary);
  margin-bottom: var(--spacing-2);
  line-height: 1.6;
}

.chat-input-area {
  padding: var(--spacing-4);
  border-top: 1px solid var(--border-color);
  flex-shrink: 0;
}

.input-container {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-3);
}

.input-wrapper {
  position: relative;
  border-radius: var(--border-radius-lg);
  background: var(--bg-primary);
  border: 1px solid var(--border-color);
}

#messageInput {
  width: 100%;
  padding: var(--spacing-3) var(--spacing-12) var(--spacing-3) var(--spacing-3);
  border: none;
  border-radius: var(--border-radius-lg);
  background: transparent;
  color: var(--text-primary);
  resize: none;
  font-family: inherit;
  font-size: var(--font-size-base);
  min-height: 80px;
  max-height: 150px;
}

#messageInput:focus {
  outline: none;
  border-color: var(--primary-color);
}

.input-actions {
  position: absolute;
  right: var(--spacing-2);
  bottom: var(--spacing-2);
  display: flex;
  gap: var(--spacing-2);
}

.voice-btn, .send-btn {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: none;
  background: var(--primary-gradient);
  color: var(--text-inverse);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-base);
  transition: var(--transition-base);
  box-shadow: var(--shadow-sm);
}

.voice-btn:hover, .send-btn:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.voice-btn:active {
  background: var(--danger-gradient);
}

/* 底部状态栏 */
.footer {
  background: var(--bg-card);
  border-top: 1px solid var(--border-color);
  padding: var(--spacing-2) var(--spacing-4);
  flex-shrink: 0;
}

.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.status-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-2);
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: var(--z-index-modal);
}

.modal.show {
  display: flex;
}

.modal-content {
  background: var(--bg-primary);
  border-radius: var(--border-radius-xl);
  box-shadow: var(--shadow-xl);
  width: 90%;
  max-width: 600px;
  max-height: 90vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  padding: var(--spacing-4);
  border-bottom: 1px solid var(--border-color);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-header h3 {
  margin: 0;
  color: var(--text-primary);
}

.close-btn {
  background: none;
  border: none;
  font-size: var(--font-size-2xl);
  cursor: pointer;
  color: var(--text-secondary);
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-btn:hover {
  background: var(--bg-secondary);
  color: var(--text-primary);
}

.modal-body {
  padding: var(--spacing-4);
  overflow-y: auto;
  flex: 1;
}

.setting-group {
  margin-bottom: var(--spacing-4);
}

.setting-group label {
  display: block;
  margin-bottom: var(--spacing-2);
  font-weight: 500;
  color: var(--text-primary);
}

.form-select {
  width: 100%;
  padding: var(--spacing-2) var(--spacing-3);
  border: 1px solid var(--border-color);
  border-radius: var(--border-radius-md);
  background: var(--bg-primary);
  color: var(--text-primary);
  font-family: inherit;
  font-size: var(--font-size-base);
}

.form-select:focus {
  outline: none;
  border-color: var(--primary-color);
}

.tabs {
  margin-top: var(--spacing-4);
}

.tab-header {
  display: flex;
  border-bottom: 1px solid var(--border-color);
  margin-bottom: var(--spacing-4);
}

.tab-btn {
  padding: var(--spacing-2) var(--spacing-4);
  border: none;
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
  font-weight: 500;
  border-bottom: 2px solid transparent;
}

.tab-btn.active {
  color: var(--primary-color);
  border-bottom-color: var(--primary-color);
}

.tab-pane {
  display: none;
}

.tab-pane.active {
  display: block;
}

.modal-footer {
  padding: var(--spacing-4);
  border-top: 1px solid var(--border-color);
  display: flex;
  justify-content: flex-end;
  gap: var(--spacing-3);
}

/* 加载动画 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: var(--z-index-modal);
  backdrop-filter: blur(5px);
}

.loading-overlay.show {
  display: flex;
}

.loading-spinner-large {
  width: 48px;
  height: 48px;
  border: 4px solid rgba(255, 255, 255, 0.3);
  border-top: 4px solid var(--text-inverse);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: var(--spacing-4);
}

.loading-content h3 {
  color: var(--text-inverse);
  margin-bottom: var(--spacing-2);
}

.loading-content p {
  color: rgba(255, 255, 255, 0.8);
}

/* 通知容器 */
.notification-container {
  position: fixed;
  top: var(--spacing-4);
  right: var(--spacing-4);
  z-index: var(--z-index-tooltip);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-2);
}

.notification {
  display: flex;
  align-items: center;
  gap: var(--spacing-3);
  padding: var(--spacing-3) var(--spacing-4);
  border-radius: var(--border-radius-lg);
  color: var(--text-inverse);
  box-shadow: var(--shadow-lg);
  animation: slideIn 0.3s ease-out;
  max-width: 300px;
}

@keyframes slideIn {
  from { transform: translateX(100%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

.notification-success {
  background: var(--success-gradient);
  border-left: 4px solid var(--success-color);
}

.notification-error {
  background: var(--danger-gradient);
  border-left: 4px solid var(--danger-color);
}

.notification-warning {
  background: var(--warning-gradient);
  border-left: 4px solid var(--warning-color);
}

.notification-info {
  background: var(--info-gradient);
  border-left: 4px solid var(--info-color);
}

.notification-close {
  background: none;
  border: none;
  color: rgba(255, 255, 255, 0.6);
  cursor: pointer;
  font-size: var(--font-size-base);
  margin-left: auto;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: var(--transition-base);
}

.notification-close:hover {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

/* 全屏数字人模式 */
.app-container.fullscreen-avatar {
  margin: 0;
  border-radius: 0;
  height: 100vh;
}

.app-container.fullscreen-avatar .chat-layout {
  height: 100%;
}

.app-container.fullscreen-avatar .avatar-section {
  flex: 1;
}

.app-container.fullscreen-avatar .chat-section {
  position: absolute;
  right: 0;
  top: 0;
  width: 400px;
  height: 100%;
  background: rgba(0, 0, 0, 0.8);
  z-index: 10001;
  display: flex;
  flex-direction: column;
  transition: transform 0.3s ease;
}

.app-container.fullscreen-avatar.chat-hidden .chat-section {
  transform: translateX(100%);
}

.app-container.fullscreen-avatar .avatar-video-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.app-container.fullscreen-avatar #avatarVideo {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;
}

.video-controls {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 16px;
  background: rgba(0, 0, 0, 0.7);
  padding: 12px 20px;
  border-radius: 30px;
  z-index: 10001;
}

.video-controls .btn {
  background: rgba(255, 255, 255, 0.2);
  border: none;
  color: white;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.3s ease;
}

.video-controls .btn:hover {
  background: rgba(255, 255, 255, 0.3);
}

/* 收起聊天框模式 */
.chat-hidden .chat-section {
  display: none;
}

.chat-hidden .avatar-section {
  width: 100%;
}

/* 响应式设计 */
@media (max-width: 1200px) {
  .chat-layout {
    flex-direction: column;
  }
  
  .avatar-section, .chat-section {
    width: 100%;
    max-width: none;
  }
  
  .chat-section {
    flex: 0 0 auto;
    max-height: 40%;
  }
  
  .app-container {
    margin: 10px;
    border-radius: 15px;
  }
  
  .header-content {
    padding: 0 20px;
  }
  
  .main-content {
    padding: 15px;
  }
}

@media (max-width: 768px) {
  .header-controls {
    gap: 10px;
  }
  
  .logo-text .subtitle {
    display: none;
  }
  
  .control-group {
    gap: 10px;
  }
  
  .control-btn {
    width: 45px;
    height: 45px;
    font-size: 16px;
  }
  
  .status-bar {
    flex-direction: column;
    gap: 10px;
    height: auto;
    padding: 15px 0;
  }
  
  .modal-content {
    width: 95%;
    max-height: 90vh;
  }
  
  .form-group {
    flex-direction: column;
  }
  
  .avatar-control-buttons {
    flex-wrap: wrap;
  }
  
  .avatar-control-buttons .btn {
    flex: none;
    min-width: 120px;
  }
  
  .local-video-wrapper {
    width: 100px;
    height: 75px;
  }
}

@media (max-width: 480px) {
  body {
    overflow: auto;
    height: auto;
  }
  
  .app-container {
    margin: 5px;
    border-radius: 10px;
    height: auto;
    min-height: 100vh;
  }
  
  .chat-layout {
    gap: 15px;
  }
  
  .message {
    max-width: 90%;
  }
  
  .input-wrapper {
    flex-direction: column;
  }
  
  #messageInput {
    padding: 15px 15px 60px 15px;
  }
  
  .input-actions {
    bottom: 15px;
    right: 15px;
  }
  
  .chat-section {
    position: fixed;
    bottom: 0;
    right: 0;
    width: 100%;
    height: 40%;
    z-index: 1000;
  }
}